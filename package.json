{
  "name": "mush-api.js",
  "description": "Unofficial Mush API wrapper for Node.js",
  "version": "1.0.2",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "keywords": [
    "mush",
    "api",
    "wrapper"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/murilommelo/mush-api.js.git"
  },
  "bugs": {
    "url": "https://github.com/murilommelo/mush-api.js/issues"
  },
  "homepage": "https://github.com/murilommelo/mush-api.js#readme",
  "author": "murilommelo (https://github.com/murilommelo/)",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "test": "vitest run --typecheck",
    "build": "tsc --noEmit && tsup",
    "lint": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unplugin-replace": "^0.7.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "engineStrict": true
}